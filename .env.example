# Supabase — lấy từ Project Settings → API (https://supabase.com/dashboard)
# Sao chép file này thành .env.local rồi điền giá trị thật.
# Khi để trống, app chạy ở "chế độ dev" (không yêu cầu đăng nhập).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chỉ dùng phía server (KHÔNG có tiền tố NEXT_PUBLIC). Cần cho thao tác admin/seed.
SUPABASE_SERVICE_ROLE_KEY=

# URL gốc site (cho link trong email). VD: https://bnb.vercel.app
NEXT_PUBLIC_SITE_URL=

# Gửi email tự động qua Resend (https://resend.com). Để trống → không gửi email (app vẫn chạy).
RESEND_API_KEY=
# Địa chỉ gửi (domain đã verify ở Resend). Mặc định dùng onboarding@resend.dev để thử.
EMAIL_FROM="Bếp Ngọc Bảo <onboarding@resend.dev>"

# Haravan Open Platform — CHỈ cần access token (endpoint apis.haravan.com/com, token tự
# định danh shop). Để trống → tầng Haravan chạy STUB (dữ liệu mẫu offline), app vẫn chạy.
HARAVAN_API_TOKEN=
HARAVAN_SHOP_DOMAIN=
# Secret webhook để xác thực HMAC khi Haravan đẩy sự kiện real-time (tồn kho/sản phẩm/đơn)
# tới /api/haravan/webhook. Để trống → endpoint chấp nhận không kiểm HMAC (chỉ nên dùng nội bộ).
HARAVAN_WEBHOOK_SECRET=

# Thiết kế bếp AI (/design) — sinh phối cảnh bếp. Điền 1 trong 2 khoá để bật ảnh thật;
# để TRỐNG cả hai → /design dùng ảnh minh hoạ (placeholder), app vẫn chạy bình thường.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Zalo ZNS — gửi tin chăm sóc/nhắc bảo hành tới khách qua Zalo OA. Để trống → no-op.
ZALO_ZNS_ACCESS_TOKEN=
ZALO_ZNS_TEMPLATE_CARE=

# Zalo OA (chat 2 chiều /inbox) — access token Official Account để gửi/nhận tin hội thoại.
# Để trống → tin trả lời chỉ lưu nội bộ (chế độ xem trước). Secret để xác thực webhook Zalo.
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_SECRET_KEY=

# Bí mật bảo vệ cron (Vercel Cron gửi header Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=

# Secret bảo vệ webhook nhận Lead (/api/leads/webhook) từ form FB/TikTok/Zalo.
# Khi đặt → request BẮT BUỘC gửi body.secret hoặc header x-webhook-secret khớp.
# Để trống → endpoint nhận mọi request (chỉ nên dùng nội bộ / khi thử).
LEADS_WEBHOOK_SECRET=
