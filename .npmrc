# node_modules phẳng (không symlink) — cần cho build OpenNext/Cloudflare trên Windows.
# OpenNext tái tạo symlink khi copy traced files (Windows chặn → EPERM); và phân tích
# tĩnh/bundle của OpenNext không hợp với layout symlink của pnpm (gây "Dynamic require" → 500).
node-linker=hoisted
shamefully-hoist=true
